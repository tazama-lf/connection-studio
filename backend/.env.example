# Database Configuration
DB_HOST=localhost
DB_USER=postgres
DB_PASS=newpassword
DB_NAME=postgres
DB_PORT=5432

# Application Configuration
NODE_ENV=dev
MAX_CPU=2               
FUNCTION_NAME=connection-studio-backend

# Session Management
SESSION_TIMEOUT_MINUTES=30

# Tazama Authentication
TAZAMA_AUTH_URL=http://localhost:3020/v1/auth/login
AUTH_PUBLIC_KEY_PATH=public-key.pem
CERT_PATH_PUBLIC=public-key.pem

# Database Configuration (used by Knex and app)
CONFIGURATION_DATABASE_URL=postgresql://postgres:newpassword@localhost:5432/postgres
CONFIGURATION_DATABASE=postgres
CONFIGURATION_DATABASE_USER=postgres
CONFIGURATION_DATABASE_PASSWORD=newpassword

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-here
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=Tazama Connection Studio
